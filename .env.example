# QuantPlatform Environment Variables
# Copy to .env and fill in values

# =============================================================================
# DOMAIN & CLOUDFLARE
# =============================================================================
DOMAIN=quant-platform.com
API_URL=https://api.quant-platform.com
# Public site URL used for SEO metadata, sitemap, and OG images
NEXT_PUBLIC_SITE_URL=https://quant-platform.com
# Used by scripts/setup-dns.py (DNS bootstrapping) and optional cache purging via API
CLOUDFLARE_ZONE_ID=
#
# Preferred: API Token (Authorization: Bearer ...) with DNS edit permissions
CLOUDFLARE_API_TOKEN=
#
# Alternative: Global API Key (X-Auth-Email / X-Auth-Key)
CLOUDFLARE_AUTH_EMAIL=
CLOUDFLARE_AUTH_KEY=
#
# Optional: origin server IP to use when creating new A records (otherwise inferred)
CLOUDFLARE_ORIGIN_IP=

# =============================================================================
# NGINX / TLS (Origin)
# =============================================================================
# Cloudflare SSL mode is currently set to "Full" which requires HTTPS on the origin.
# Put an origin certificate + key on the server (example paths below) and mount them into nginx.
NGINX_SSL_CERT_PATH=/opt/quant-platform/env/nginx/ssl/origin.crt
NGINX_SSL_KEY_PATH=/opt/quant-platform/env/nginx/ssl/origin.key

# =============================================================================
# SUPABASE AUTH
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_JWT_SECRET=REPLACE_ME  # Get from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME

# =============================================================================
# SENTRY (Error Tracking)
# =============================================================================
SENTRY_DSN=REPLACE_ME

# =============================================================================
# REDDIT (Social Sentiment - Optional)
# =============================================================================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=QuantPlatform/1.0

# =============================================================================
# LLM (Groq - Feature Flagged)
# =============================================================================
ENABLE_LLM=false
GROQ_API_KEY=REPLACE_ME
GROQ_BASE_MODEL=llama-3.3-70b-versatile
GROQ_DEEP_MODEL=openai/gpt-oss-120b

# =============================================================================
# DEEP RESEARCH RAG (LlamaIndex)
# =============================================================================
RAG_STORE_URI=local://
RAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
RAG_K_WATCHLIST_DEEP=6
RAG_TOP_K_DEEP=12

# =============================================================================
# STRIPE (Payments)
# =============================================================================
# Server enforces a single paid tier:
#   Pro = USD 2.99/month (fixed in gateway checkout logic)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME  # Create at https://dashboard.stripe.com/webhooks
# Optional comma-separated host allowlist for Stripe checkout return URLs
# Example: BILLING_ALLOWED_RETURN_HOSTS=quant-platform.com,app.quant-platform.com,localhost,127.0.0.1
BILLING_ALLOWED_RETURN_HOSTS=

# =============================================================================
# S3 / OBJECT STORAGE (Hetzner)
# =============================================================================
S3_BUCKET_NAME=quant-platform-reports
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_SERVICE_URL=https://nbg1.your-objectstorage.com

# =============================================================================
# POSTHOG ANALYTICS
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# MASSIVE API (Stock Data & Logos)
# =============================================================================
MASSIVE_API_KEY=

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=quant-platform
POSTGRES_PASSWORD=quant-platform_dev_password  # Change for production
POSTGRES_DB=quant-platform_db
DATABASE_URL=Host=postgres;Database=quant-platform_db;Username=quant-platform;Password=quant-platform_dev_password

# =============================================================================
# INTERNAL / JOBS
# =============================================================================
INTERNAL_API_SECRET=REPLACE_ME

# =============================================================================
# GRAFANA
# =============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=REPLACE_ME

# =============================================================================
# ALERTING / NOTIFICATIONS
# =============================================================================
# Slack (recommended): Incoming Webhook URL from your Slack app.
ALERT_SLACK_WEBHOOK_URL=
# Optional Slack channel override (ex: #prod-alerts). If omitted, Slack app default is used.
ALERT_SLACK_CHANNEL=

# Generic webhook endpoint (for Discord/custom gateway). Ignored when ALERT_SLACK_WEBHOOK_URL is set.
ALERT_WEBHOOK_URL=
ALERT_GROUP_WAIT=30s
ALERT_GROUP_INTERVAL=5m
ALERT_REPEAT_INTERVAL=4h

# =============================================================================
# DEMO / PORTFOLIO ACCESS
# =============================================================================
# Secret token for the magic-link demo URL: /demo?token=<DEMO_TOKEN>
# Share this URL with hiring managers — no signup or payment required.
# Rotate this value to invalidate existing links.
# Generate with: openssl rand -hex 24
DEMO_TOKEN=REPLACE_ME
